# Dev defaults only - not for prod use
ARGILLA_PORT=6900
ARGILLA_USERNAME=argilla
ARGILLA_PASSWORD=argilla123
ARGILLA_API_KEY=argilla.apikey
POSTGRES_PASSWORD=postgres

# External backing services (uncomment to use external services instead of bundled)
# When set, run `make docker-up-external` to skip local containers
# ARGILLA_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/argilla
# ARGILLA_ELASTICSEARCH=http://host:9200
# ARGILLA_REDIS_URL=redis://host:6379/0
