# Dev defaults only — not for production use.
#
ARGILLA_PORT=6900

# Owner account — created once on first boot with these credentials.
# USERNAME and PASSWORD are for browser login by the Argilla owner.
# API_KEY is the token used by `pragmata annotation` CLI commands (set ARGILLA_API_KEY
# in your shell or CI secrets to the same value so pragmata can authenticate).
ARGILLA_USERNAME=argilla
ARGILLA_PASSWORD=argilla123
ARGILLA_API_KEY=argilla.apikey

# Postgres password used by the bundled postgres service and interpolated into
# ARGILLA_DATABASE_URL when no external DB is configured.
POSTGRES_PASSWORD=postgres

# External backing services — uncomment and fill in whichever you want to provide
# externally, then use the matching make target:
#   make docker-up-external-pg  →  external Postgres only  (set ARGILLA_DATABASE_URL)
#   make docker-up-external-es  →  external ES only        (set ARGILLA_ELASTICSEARCH)
#   make docker-up-external     →  all external            (set all three)
# ARGILLA_DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:5432/argilla
# ARGILLA_ELASTICSEARCH=http://<host>:9200
# ARGILLA_REDIS_URL=redis://<host>:6379/0
