# UAT environment — use a different Docker Compose project name for isolation:
#   docker compose --env-file .env.uat -p annotation-uat up
#
# This gives the UAT stack its own containers, volumes, and network,
# fully isolated from dev without any application-level prefixing.

ARGILLA_PORT=6901
ARGILLA_USERNAME=argilla
ARGILLA_PASSWORD=changeme-uat
ARGILLA_API_KEY=argilla.uat.apikey
POSTGRES_PASSWORD=postgres-uat

# External backing services — same options as .env.dev.example:
#   make docker-up-external-pg  →  external Postgres only  (set ARGILLA_DATABASE_URL)
#   make docker-up-external-es  →  external ES only        (set ARGILLA_ELASTICSEARCH)
#   make docker-up-external     →  all external            (set all three)
# ARGILLA_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/argilla
# ARGILLA_ELASTICSEARCH=http://host:9200
# ARGILLA_REDIS_URL=redis://host:6379/0
